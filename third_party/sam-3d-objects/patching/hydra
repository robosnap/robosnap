#!/usr/bin/env python
import os, hydra, urllib.request, base64, time

if hydra.__version__ != "1.3.2":
    raise RuntimeError("different hydra version has been found, cannot patch")

hydra_root = os.path.dirname(hydra.__file__)
utils_path = os.path.join(hydra_root, "core", "utils.py")

URLS = [
 "https://raw.githubusercontent.com/gleize/hydra/78f00766b5f37672aa7232ebbf01bdd74246bd60/hydra/core/utils.py",
 "https://raw.gitmirror.com/gleize/hydra/78f00766b5f37672aa7232ebbf01bdd74246bd60/hydra/core/utils.py"
]

# Optional: read proxy from env and install opener with auth if needed
proxy = os.environ.get("https_proxy") or os.environ.get("HTTPS_PROXY") or os.environ.get("http_proxy") or os.environ.get("HTTP_PROXY")
if proxy:
    # handle user:pass@host:port
    if "@" in proxy and "://" in proxy:
        scheme, rest = proxy.split("://", 1)
        auth, addr = rest.split("@", 1)
        proxy_handler = urllib.request.ProxyHandler({scheme: f"{scheme}://{addr}"})
        opener = urllib.request.build_opener(proxy_handler)
        opener.addheaders = [("Proxy-Authorization", "Basic " + base64.b64encode(auth.encode()).decode())]
    else:
        opener = urllib.request.build_opener(urllib.request.ProxyHandler({"http": proxy, "https": proxy}))
    urllib.request.install_opener(opener)

for url in URLS:
    try:
        print("Trying", url)
        urllib.request.urlretrieve(url, utils_path)
        print("Patched:", utils_path)
        break
    except Exception as e:
        print("Failed:", e)
        time.sleep(1)
else:
    raise SystemExit("All downloads failed")