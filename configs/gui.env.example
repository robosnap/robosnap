# Copy to configs/gui.env and edit local paths.
# The launch script sources this file as bash.

# ROBOSNAP_ROOT defaults to the repository root in scripts/run_gui.sh.
# Uncomment only when launching from another location.
# ROBOSNAP_ROOT=/path/to/robosnap
CHECKPOINT_DIR=${ROBOSNAP_ROOT}/checkpoints

# Python runtimes. Use separate envs if video segmentation, asset generation, and articulation need different deps.
PY_SAM3=python
PY_ASSET=python
PY_ARTICULATE=python
# Optional when calling /path/to/env/bin/python without activating conda.
# scripts/run_gui.sh derives these automatically for absolute conda Python paths.
PY_ASSET_CONDA_PREFIX=
PY_ARTICULATE_CONDA_PREFIX=
# Input and output. Defaults run the checked-in demo and write generated files under outputs/.
VIDEO=${ROBOSNAP_ROOT}/examples/video.mp4
OUT_DIR=${ROBOSNAP_ROOT}/outputs/example/multi_mask
PORT=7897
SHARE=0
DEBUG=0
MAX_FRAMES=20

# SAM3 segmentation checkpoint. See README.md for download and local-cache options.
SAM3_DIR=${ROBOSNAP_ROOT}/third_party/sam3
SAM3_CKPT=${CHECKPOINT_DIR}/sam3/sam3.pt

# SAM3D object generation code and checkpoint config. SAM3D_CONFIG must sit next to all files it references.
SAM3D_DIR=${ROBOSNAP_ROOT}/third_party/sam-3d-objects
SAM3D_CONFIG=${CHECKPOINT_DIR}/sam-3d-objects/pipeline.yaml

# Articulate Tool page.
ARTICULATE_APP=${ROBOSNAP_ROOT}/third_party/Hunyuan3D-Part/P3-SAM/demo/app.py
ARTICULATE_CKPT=${CHECKPOINT_DIR}/articulate/articulate.safetensors
ARTICULATE_BASE_PORT=8180
SONATA_CACHE_DIR=${CHECKPOINT_DIR}/sonata

# Default iframe URL is http://127.0.0.1:{port}.
# Set this when the browser reaches the Articulate Tool page through a proxy/tunnel.
# Example: ARTICULATE_PUBLIC_URL_TEMPLATE=https://your-proxy.example/{port}/
ARTICULATE_PUBLIC_URL_TEMPLATE=

# Optional runtime smoke-test object for RUN_ARTICULATE_STARTUP=1.
# This should be an object directory containing an already generated GLB.
ARTICULATE_TEST_DATA_DIR=
ARTICULATE_TEST_PORT=${ARTICULATE_BASE_PORT}
ARTICULATE_TEST_POINT_NUM=20000

# Optional cache roots. MoGe cache avoids a SAM3D dependency download during asset generation.
HF_HOME=${CHECKPOINT_DIR}/hf_cache
TORCH_HOME=${CHECKPOINT_DIR}/torch_cache
# Optional: uncomment on machines that need a Hugging Face mirror.
# HF_ENDPOINT=https://hf-mirror.com
# By default scripts/run_gui.sh unsets SOCKS proxy variables because gradio/httpx needs socksio for them.
ROBOSNAP_KEEP_PROXY=0

# Optional extra Gradio file-access roots, colon-separated.
GRADIO_ALLOWED_ROOTS=
