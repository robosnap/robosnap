# Optional overrides for the automatic layered-scene pipeline.

ROBOSNAP_ROOT=${ROBOSNAP_ROOT:-$(pwd)}
CHECKPOINT_DIR=${CHECKPOINT_DIR:-${ROBOSNAP_ROOT}/checkpoints}
HF_HOME=${HF_HOME:-${CHECKPOINT_DIR}/hf_cache}
TORCH_HOME=${TORCH_HOME:-${CHECKPOINT_DIR}/torch_cache}
HF_HUB_DISABLE_XET=${HF_HUB_DISABLE_XET:-1}
ROBOSNAP_KEEP_PROXY=${ROBOSNAP_KEEP_PROXY:-1}

PY_AUTO=python
PY_SAM3=python
PY_ASSET=python
PY_VGGT=${PY_ASSET}
# Optional local VGGT model.pt. Leave empty to use Hugging Face cache/download.
VGGT_CKPT=
PY_ALIGN=${PY_ASSET}
PY_LYRA=python
PY_LYRA_CONDA_PREFIX=
PY_SIM_READY=python

SAM3_DIR=${ROBOSNAP_ROOT}/third_party/sam3
SAM3_CKPT=${CHECKPOINT_DIR}/sam3/sam3.pt
SAM3D_DIR=${ROBOSNAP_ROOT}/third_party/sam-3d-objects
SAM3D_CONFIG=${CHECKPOINT_DIR}/sam-3d-objects/pipeline.yaml
VGGT_DIR=${ROBOSNAP_ROOT}/third_party/vggt
LYRA_DIR=${ROBOSNAP_ROOT}/third_party/lyra
LYRA2_CHECKPOINT_ROOT=${LYRA2_CHECKPOINT_ROOT:-${CHECKPOINT_DIR}/lyra2/checkpoints}
LYRA_CHECKPOINT_DIR=${LYRA_CHECKPOINT_DIR:-${CHECKPOINT_DIR}/lyra}
# Validated low-memory profile for a 48 GB GPU. Use 480,832 or higher on an 80 GB GPU.
LYRA_RESOLUTION=${LYRA_RESOLUTION:-352,624}
LYRA_USE_DMD=${LYRA_USE_DMD:-1}
LYRA_OFFLOAD=${LYRA_OFFLOAD:-1}
LYRA_RECON_DA3_MAX_FRAMES=${LYRA_RECON_DA3_MAX_FRAMES:-32}
ROBOSNAP_MAX_JOBS=${ROBOSNAP_MAX_JOBS:-1}
LYRA_DA3_MODEL_PATH=${LYRA2_CHECKPOINT_ROOT}/recon/model.pt
SF_REAL2SIM_USE_CACHED_COLLISIONS=${SF_REAL2SIM_USE_CACHED_COLLISIONS:-1}

INPUT_IMAGE=${INPUT_IMAGE:-${ROBOSNAP_ROOT}/examples/test1.png}
OUTPUT_DIR=${OUTPUT_DIR:-${ROBOSNAP_ROOT}/outputs/automatic}
DEVICE=${DEVICE:-cuda:0}
CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-}
INPAINT_DILATION=${INPAINT_DILATION:-7}
# INPAINT_EXTRA_MASK=/path/to/additional_semantic_mask.png

# The default Gemini adapter handles object discovery and background editing.
# Set OBJECT_FILE to bypass object discovery, or replace either command with another provider.
GEMINI_TEXT_MODEL=gemini-3.5-flash
VLM_COMMAND="${PY_AUTO} ${ROBOSNAP_ROOT}/scripts/run_gemini_vlm.py --image {image} --prompt {prompt} --output {output_json}"
INPAINT_PROMPT=${ROBOSNAP_ROOT}/configs/prompts/background_inpaint.txt
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
INPAINT_COMMAND="${PY_AUTO} ${ROBOSNAP_ROOT}/scripts/run_gemini_image_edit.py --image {image} --mask {mask} --prompt {prompt} --output {output} --status {status}"

# OBJECT_FILE=/path/to/objects.json
# VLM_COMMAND='python /path/to/list_objects.py --image {image} --prompt {prompt} --output {output_json}'
# INPAINT_COMMAND='python /path/to/inpaint.py --image {image} --mask {mask} --prompt {prompt} --output {output} --status {status}'
