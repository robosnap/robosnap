# Optional local override template for the automatic layered-scene pipeline.
# Copy to configs/auto_pipeline.env and edit local paths as needed.

ROBOSNAP_ROOT=${ROBOSNAP_ROOT:-$(pwd)}
CHECKPOINT_DIR=${CHECKPOINT_DIR:-${ROBOSNAP_ROOT}/checkpoints}
# Shared model caches. Override these paths for persistent shared storage.
HF_HOME=${HF_HOME:-${CHECKPOINT_DIR}/hf_cache}
TORCH_HOME=${TORCH_HOME:-${CHECKPOINT_DIR}/torch_cache}
HF_HUB_DISABLE_XET=${HF_HUB_DISABLE_XET:-1}
ROBOSNAP_KEEP_PROXY=${ROBOSNAP_KEEP_PROXY:-1}

PY_AUTO=python
PY_SAM3=python
PY_ASSET=python
PY_VGGT=${PY_ASSET}
# Optional local VGGT model.pt. Leave empty to use Hugging Face cache/download.
VGGT_CKPT=
PY_ALIGN=${PY_ASSET}
PY_LYRA=python
PY_LYRA_CONDA_PREFIX=
PY_SIM_READY=python

SAM3_DIR=${ROBOSNAP_ROOT}/third_party/sam3
SAM3_CKPT=${CHECKPOINT_DIR}/sam3/sam3.pt
SAM3D_DIR=${ROBOSNAP_ROOT}/third_party/sam-3d-objects
SAM3D_CONFIG=${CHECKPOINT_DIR}/sam-3d-objects/pipeline.yaml
VGGT_DIR=${ROBOSNAP_ROOT}/third_party/vggt
LYRA_DIR=${ROBOSNAP_ROOT}/third_party/lyra
LYRA2_CHECKPOINT_ROOT=${LYRA2_CHECKPOINT_ROOT:-${CHECKPOINT_DIR}/lyra2/checkpoints}
LYRA_CHECKPOINT_DIR=${LYRA_CHECKPOINT_DIR:-${CHECKPOINT_DIR}/lyra}
# Lyra-2 first generates a moving exploration video, then reconstructs it with VIPE+DA3.
LYRA_PROMPT="A clean realistic indoor scene with stable architecture, lighting, and materials."
LYRA_FRAMES_IN=${LYRA_FRAMES_IN:-81}
LYRA_FRAMES_OUT=${LYRA_FRAMES_OUT:-81}
# Validated low-memory profile for a 48 GB GPU. Use 480,832 or higher on an 80 GB GPU.
LYRA_RESOLUTION=${LYRA_RESOLUTION:-352,624}
LYRA_ZOOM_IN_STRENGTH=${LYRA_ZOOM_IN_STRENGTH:-0.35}
LYRA_ZOOM_OUT_STRENGTH=${LYRA_ZOOM_OUT_STRENGTH:-0.65}
LYRA_USE_DMD=${LYRA_USE_DMD:-1}
LYRA_OFFLOAD=${LYRA_OFFLOAD:-1}
LYRA_RECON_DA3_MAX_FRAMES=${LYRA_RECON_DA3_MAX_FRAMES:-32}
LYRA_NO_VIPE=${LYRA_NO_VIPE:-0}
LYRA_MAX_FRAMES=${LYRA_MAX_FRAMES:-0}
LYRA_DA3_MAX_FRAMES=${LYRA_DA3_MAX_FRAMES:-128}
LYRA_MAX_RESOLUTION=${LYRA_MAX_RESOLUTION:-0}
LYRA_GS_DOWN_RATIO=${LYRA_GS_DOWN_RATIO:-2}
ROBOSNAP_MAX_JOBS=${ROBOSNAP_MAX_JOBS:-1}
# Optional exact DA3 safetensors path. Leave empty to use Hugging Face cache lookup/download.
LYRA_DA3_MODEL_PATH=${LYRA2_CHECKPOINT_ROOT}/recon/model.pt
# Optional compatibility shim when the SF-Real2Sim Python has sapien but lacks open3d.
# SF_REAL2SIM_EXTRA_PYTHONPATH=/path/to/python/site-packages
SF_REAL2SIM_EXTRA_PYTHONPATH=${SF_REAL2SIM_EXTRA_PYTHONPATH:-}
SF_REAL2SIM_COLLISION_METHOD=${SF_REAL2SIM_COLLISION_METHOD:-vhacd}
SF_REAL2SIM_USE_CACHED_COLLISIONS=${SF_REAL2SIM_USE_CACHED_COLLISIONS:-0}
SF_REAL2SIM_DISABLE_COLLISION_SPLIT=${SF_REAL2SIM_DISABLE_COLLISION_SPLIT:-1}
SF_REAL2SIM_NUM_ROUNDS=${SF_REAL2SIM_NUM_ROUNDS:-30}
# Keep enabled by default; set to 1 only to bypass SF's initial penetration correction.
SF_REAL2SIM_DISABLE_INITIAL_POSE_REGULARIZATION=${SF_REAL2SIM_DISABLE_INITIAL_POSE_REGULARIZATION:-0}
# Optional SoM+VLM graph. Without it, RoboSnap infers support edges from masks, captions, and poses.
SF_SCENE_GRAPH_PATH=${SF_SCENE_GRAPH_PATH:-}
SF_REAL2SIM_SDF_STEPS_PER_ROUND=${SF_REAL2SIM_SDF_STEPS_PER_ROUND:-15}
SF_REAL2SIM_SIM_STEPS_PER_ROUND=${SF_REAL2SIM_SIM_STEPS_PER_ROUND:-8}
SF_REAL2SIM_SIM_DAMPING_STEPS=${SF_REAL2SIM_SIM_DAMPING_STEPS:-6}
SF_REAL2SIM_SEED=${SF_REAL2SIM_SEED:-0}
SF_SECOND_PASS_NUM_ROUNDS=${SF_SECOND_PASS_NUM_ROUNDS:-30}
SF_SECOND_PASS_SDF_STEPS_PER_ROUND=${SF_SECOND_PASS_SDF_STEPS_PER_ROUND:-15}
SF_SECOND_PASS_SIM_STEPS_PER_ROUND=${SF_SECOND_PASS_SIM_STEPS_PER_ROUND:-8}
SF_SECOND_PASS_SIM_DAMPING_STEPS=${SF_SECOND_PASS_SIM_DAMPING_STEPS:-6}
SF_SECOND_PASS_REGULARIZATION_WEIGHT=${SF_SECOND_PASS_REGULARIZATION_WEIGHT:-1.0}
SF_SECOND_PASS_MIN_REPROJECTION_RATIO=${SF_SECOND_PASS_MIN_REPROJECTION_RATIO:-0.98}
SF_REAL2SIM_CONVERGENCE_THRESHOLD=${SF_REAL2SIM_CONVERGENCE_THRESHOLD:-0.001}
SF_REAL2SIM_SDF_RESOLUTION=${SF_REAL2SIM_SDF_RESOLUTION:-128}
SF_REAL2SIM_NUM_SURFACE_POINTS=${SF_REAL2SIM_NUM_SURFACE_POINTS:-1024}
SF_REAL2SIM_NO_MAKE_SDF_MESH_WATERTIGHT=${SF_REAL2SIM_NO_MAKE_SDF_MESH_WATERTIGHT:-0}
SF_REAL2SIM_NO_REQUIRE_WATERTIGHT_SDF_MESH=${SF_REAL2SIM_NO_REQUIRE_WATERTIGHT_SDF_MESH:-0}
SF_REAL2SIM_SDF_WATERTIGHT_METHOD=${SF_REAL2SIM_SDF_WATERTIGHT_METHOD:-voxel}
SF_REAL2SIM_SDF_WATERTIGHT_VOXEL_RESOLUTION=${SF_REAL2SIM_SDF_WATERTIGHT_VOXEL_RESOLUTION:-96}
SF_PROJECTION_MIN_SCALE=${SF_PROJECTION_MIN_SCALE:-0.35}
SF_PROJECTION_MAX_SCALE=${SF_PROJECTION_MAX_SCALE:-1.5}
SF_PROJECTION_MIN_IOU=${SF_PROJECTION_MIN_IOU:-0.55}

INPUT_IMAGE=${ROBOSNAP_ROOT}/examples/image.png
OUTPUT_DIR=${ROBOSNAP_ROOT}/outputs/release_demo_2
DEVICE=cuda:0
CUDA_VISIBLE_DEVICES=
INPAINT_DILATION=${INPAINT_DILATION:-7}
# INPAINT_EXTRA_MASK=/path/to/additional_semantic_mask.png

# Provide one of these for object discovery.
# OBJECT_PROMPTS="table, cup, bottle"
# OBJECT_FILE=/path/to/object.txt
# VLM_PROMPT=/path/to/object_discovery_prompt.txt
# VLM_COMMAND='python /path/to/list_objects.py --image {image} --prompt {prompt} --output {output_json}'

# Gemini semantic background editing is the release default.
# Export GEMINI_API_KEY or GOOGLE_API_KEY before running.
INPAINT_PROMPT=${ROBOSNAP_ROOT}/configs/prompts/background_inpaint.txt
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
INPAINT_COMMAND="python ${ROBOSNAP_ROOT}/scripts/run_gemini_image_edit.py --image {image} --mask {mask} --prompt {prompt} --output {output} --status {status} --raw-output ${OUTPUT_DIR}/complete_background_gemini_raw.png"

# Optional provider overrides.
# INPAINT_PROMPT=/path/to/background_inpaint_prompt.txt
# INPAINT_COMMAND='python /path/to/inpaint.py --image {image} --mask {mask} --prompt {prompt} --output {output} --status {status}'
# ROBOSNAP_DIFFUSERS_PATH=/path/to/diffusers-compat-site
# INPAINT_COMMAND="python ${ROBOSNAP_ROOT}/scripts/run_diffusers_inpaint.py --image {image} --mask {mask} --prompt {prompt} --output {output}"
